# Keep the Docker build context small and reproducible. This file is shared by
# every service build, so it must not exclude a source dir that any image copies
# (producer/, serving/, dashboard/). Each Dockerfile still COPYs only its own dir.

# Virtualenvs / caches
.venv/
**/__pycache__/
*.pyc
.mypy_cache/
.ruff_cache/
.pytest_cache/

# VCS + private/local files
.git/
.gitignore
_local/

# Not needed by any image build (serving/ and dashboard/ are intentionally NOT
# excluded — their images copy them).
docs/
tests/
scripts/
airflow/
spark_jobs/
k8s/
*.md
Makefile
.pre-commit-config.yaml
docker-compose.yml
.python-version
